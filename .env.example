# No UCloud API keys are required.
# Studio and Explore use UCloud OAuth login.

# OAuth uses UCloud's registered localhost loopback callback.
# When opening the app through a remote IP, complete login by pasting the
# localhost callback URL from the browser into the login page.

# Optional extra hostnames or IPs that may access the Next.js dev server.
# Local network IPv4 addresses are detected automatically; use this for tunnels
# or custom hostnames. Values are comma-separated and should not include scheme.
# ASTRAFLOW_ALLOWED_DEV_ORIGINS=YOUR_REMOTE_IP,your-tunnel.example.com

# Optional AstraFlow Sandbox connection overrides.
# Defaults to the UCloud-compatible E2B template built from sandbox_template.
# ASTRAFLOW_SANDBOX_TEMPLATE=astraflow-desktop
# ASTRAFLOW_SANDBOX_DOMAIN=cn-wlcb.sandbox.ucloudai.com
# ASTRAFLOW_SANDBOX_API_URL=
# ASTRAFLOW_SANDBOX_URL=
# ASTRAFLOW_SANDBOX_SESSION_AUTO_PAUSE_TIMEOUT_SECONDS=300
