# No UCloud API keys are required.
# Studio and Explore use UCloud OAuth login.

# OAuth uses UCloud's registered localhost loopback callback.
# When opening the app through a remote IP, complete login by pasting the
# localhost callback URL from the browser into the login page.

# Optional extra hostnames or IPs that may access the Next.js dev server.
# Local network IPv4 addresses are detected automatically; use this for tunnels
# or custom hostnames. Values are comma-separated and should not include scheme.
# ASTRAFLOW_ALLOWED_DEV_ORIGINS=YOUR_REMOTE_IP,your-tunnel.example.com

# AstraFlow cloud API endpoint. Defaults to the production HTTPS gateway.
# ASTRAFLOW_API_BASE_URL=https://astraflow-desktop.modelverse.cn/astraflow-desktop/api

# Optional distribution channel slug. Managed channel builds fetch their
# feature, model, and OAuth configuration from the AstraFlow API at runtime.
# Use NEXT_PUBLIC_ASTRAFLOW_CHANNEL_SLUG for packaged builds so the slug is
# embedded in the Electron Next.js bundle; the slug is a public identifier.
# NEXT_PUBLIC_ASTRAFLOW_CHANNEL_SLUG=partner-name
# ASTRAFLOW_CHANNEL_SLUG=partner-name

# Optional AstraFlow Sandbox connection overrides.
# Defaults to the UCloud-compatible E2B template built from sandbox_template.
# Standard channel template id: ry2jck30zrnfwtm1fihv
# CompShare channel template id (2 vCPU / 4096 MiB): i21vxo1qnl9gmk8nqakj
# ASTRAFLOW_SANDBOX_TEMPLATE=i21vxo1qnl9gmk8nqakj
# ASTRAFLOW_SANDBOX_DOMAIN=cn-wlcb.sandbox.ucloudai.com
# ASTRAFLOW_SANDBOX_API_URL=
# ASTRAFLOW_SANDBOX_URL=

# Optional CodeBox code-server template override.
# CompShare normally selects the template from the active package automatically.
# Standard channel template id: yeyb5hbs2kweus6ku07l
# CompShare Basic 2C4G template id: i21vxo1qnl9gmk8nqakj
# CompShare Pro+ 8C8G template id: 79a9c0uxquw17scu698u
# Setting this override disables per-package template selection.
# ASTRAFLOW_CODE_SANDBOX_TEMPLATE=79a9c0uxquw17scu698u

# CodeBox GitHub Device Flow OAuth App client ID.
# Client IDs are public identifiers; Electron injects the bundled default at
# runtime, and this env var can override it for custom builds.
# GITHUB_OAUTH_CLIENT_ID=Ov23li4imZRAMlx9enez
