{
  "name": "astraflow-desktop",
  "version": "0.0.11",
  "description": "AstraFlow desktop frontend",
  "author": "UCloud",
  "main": "electron/main.cjs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "electron:build": "cross-env ASTRAFLOW_ELECTRON=1 NEXT_TELEMETRY_DISABLED=1 next build && node scripts/prepare-electron-app.mjs",
    "electron:start": "electron electron/main.cjs",
    "electron:pack": "bun run electron:build && node scripts/run-electron-builder.mjs --dir --publish never",
    "electron:dist": "bun run electron:build && node scripts/run-electron-builder.mjs --publish never",
    "electron:smoke": "node scripts/smoke-electron-package.mjs",
    "codegen:audio-openapi": "bun scripts/generate-audio-openapi.mjs",
    "codegen:image-openapi": "bun scripts/generate-image-openapi.mjs",
    "codegen:video-openapi": "bun scripts/generate-video-openapi.mjs",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@e2b/code-interpreter": "^2.6.1",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint": "^1.1.3",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.5.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@remixicon/react": "^4.9.0",
    "ai": "^7.0.4",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deepagents": "^1.10.5",
    "electron-updater": "^6.8.9",
    "fflate": "^0.8.3",
    "langchain": "^1.5.2",
    "lucide-react": "^1.22.0",
    "marked": "^18.0.5",
    "media-chrome": "^4.19.2",
    "motion": "^12.42.0",
    "next": "16.3.0-preview.5",
    "next-themes": "^0.4.6",
    "openai": "^6.45.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.12.0",
    "shiki": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@readme/openapi-parser": "^6.1.3",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "cross-env": "10.1.0",
    "electron": "42.5.2",
    "electron-builder": "26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.3.0-preview.5",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
