FROM vllm/vllm-openai:v0.21.0-cu129

RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg libsndfile1 \
    && rm -rf /var/lib/apt/lists/* \
    && uv pip install --system "vllm[audio]==0.21.0"

COPY deploy/gpu-inference/start-models.sh /opt/astraflow/start-models.sh
RUN chmod 0755 /opt/astraflow/start-models.sh

ENTRYPOINT []
CMD ["/opt/astraflow/start-models.sh"]
